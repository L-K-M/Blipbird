# Blipbird editorconfig — basic conventions until the Kotlin/Gradle build lands.
# Pre-M0: no code yet; these cover markdown docs and shell/python scripts that
# already exist or will be added.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{md,markdown}]
# Trailing whitespace can be significant in Markdown (hard line breaks), so
# leave it alone inside prose files.
trim_trailing_whitespace = false
max_line_length = off

[*.{kt,kts}]
indent_size = 4
# Kotlin: 4-space indent, no tabs. Once ktlint/detekt is wired (M0), this file
# is the source of truth it reads.

[*.{yml,yaml,json}]
indent_size = 2

[*.{sh,py}]
indent_size = 4

[Makefile]
indent_style = tab
