<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup boundary (PLAN.md §7/§18): include-only semantics — listing explicit
  includes means everything else (blipbird-ops.db, the encrypted provider_keys
  file, caches) is NOT backed up. User-authored intent travels; provider-derived
  operational data and device-bound credentials never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="blipbird-user.db" />
        <include domain="file" path="datastore/settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="blipbird-user.db" />
        <include domain="file" path="datastore/settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
