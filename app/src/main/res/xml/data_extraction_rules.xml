<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup boundary (PLAN.md §7/§18): user-authored intent (user.db, settings
  DataStore) is backed up; provider-derived operational data, the reference
  dataset, and the encrypted credential file never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="blipbird-user.db" />
        <include domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="database" path="blipbird-ops.db" />
        <exclude domain="file" path="datastore/provider_keys.pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="blipbird-user.db" />
        <include domain="file" path="datastore/settings.preferences_pb" />
        <exclude domain="database" path="blipbird-ops.db" />
        <exclude domain="file" path="datastore/provider_keys.pb" />
    </device-transfer>
</data-extraction-rules>
