# Normalize line endings across platforms; the repo is LF.
* text=auto eol=lf

# Markdown sources: treat as text (LF) — never let a Windows checkout CRLF the
# plan and analysis docs.
*.md   text eol=lf

# Scripts and config that must stay LF.
*.sh   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.xml  text eol=lf
*.gradle* text eol=lf
*.kts  text eol=lf
*.editorconfig text eol=lf

# Binary assets — never diff/merge as text.
*.png  binary
*.jpg  binary
*.webp binary
*.svg  binary
*.ttf  binary
*.otf  binary
*.keystore binary
*.jks  binary
